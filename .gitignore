# ═══════════════════════════════════════════════════
#  Attendance AI — .gitignore
# ═══════════════════════════════════════════════════

# ── Python Bytecode & Cache ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Python Packaging ──
*.egg-info/
*.egg
*.whl
build/
develop-eggs/
.eggs/
sdist/

# ── Virtual Environments ──
.env
.env.local
.env.production
.env.*.local
.venv/
venv/
env/
.cuda/
ENV/

# ── ML / Large Binary Files / AI Models ──
# Datasets
processed_dataset/

# Database files
student_index.faiss
labels.pkl
*.faiss
*.pkl

# AI Models
yolov8n.pt
yolov8n-face.pt
backend/models/insightface/det_10g.onnx
backend/models/insightface/w600k_r50.onnx
*.onnx
*.pt
*.pth
*.model
*.weights

# ── Node / Frontend ──
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local

# ── IDE & Editors ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*~

# ── OS Generated ──
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing & Coverage ──
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ── Jupyter Notebooks ──
.ipynb_checkpoints/
*.ipynb

# ── Misc ──
*.bak
*.tmp
*.temp
*.orig
